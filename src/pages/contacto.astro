<style>
	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	@keyframes slideInLeft {
		from {
			opacity: 0;
			transform: translateX(-40px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	@keyframes expandLine {
		from { transform: scaleX(0); }
		to { transform: scaleX(1); }
	}

	@keyframes glowDrift {
		0%, 100% { transform: translate(0, 0) scale(1); }
		33% { transform: translate(30px, -20px) scale(1.1); }
		66% { transform: translate(-20px, 15px) scale(0.95); }
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body, html {
		min-height: 100%;
		font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
		background-color: #050505;
		color: #fff;
	}

	.bg-grid {
		position: fixed;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
		background-size: 60px 60px;
		z-index: 0;
		animation: fadeIn 2s ease-out;
	}

	.bg-glow {
		position: fixed;
		width: 500px;
		height: 500px;
		border-radius: 50%;
		filter: blur(120px);
		opacity: 0.08;
		z-index: 0;
		pointer-events: none;
	}

	.bg-glow--1 {
		background: #6366f1;
		top: -150px;
		right: -100px;
		animation: glowDrift 12s ease-in-out infinite;
	}

	.bg-glow--2 {
		background: #06b6d4;
		bottom: -200px;
		left: -100px;
		animation: glowDrift 15s ease-in-out infinite reverse;
	}

	.page-container {
		position: relative;
		z-index: 1;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	/* --- NAV --- */
	.top-nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 2rem 3rem;
		opacity: 0;
		animation: fadeIn 0.6s ease-out 0.2s forwards;
	}

	.back-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: rgba(255, 255, 255, 0.5);
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: 1px;
		text-transform: uppercase;
		transition: color 0.3s ease, gap 0.3s ease;
	}

	.back-link:hover {
		color: #fff;
		gap: 0.8rem;
	}

	.back-arrow {
		font-size: 1.1rem;
		transition: transform 0.3s ease;
	}

	.back-link:hover .back-arrow {
		transform: translateX(-3px);
	}

	.nav-links {
		display: flex;
		gap: 2rem;
	}

	.nav-link {
		color: rgba(255, 255, 255, 0.4);
		text-decoration: none;
		font-size: 0.8rem;
		font-weight: 500;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		transition: color 0.3s ease;
		position: relative;
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 0;
		height: 1px;
		background: #6366f1;
		transition: width 0.3s ease;
	}

	.nav-link:hover {
		color: #fff;
	}

	.nav-link:hover::after {
		width: 100%;
	}

	/* --- CONTENT --- */
	.content-wrapper {
		flex: 1;
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem 3rem 4rem;
		width: 100%;
	}

	/* --- HEADER --- */
	.page-header {
		margin-bottom: 3.5rem;
		opacity: 0;
		animation: slideInLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
	}

	.section-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.8rem;
		color: #6366f1;
		letter-spacing: 2px;
		display: block;
		margin-bottom: 1rem;
	}

	.page-title {
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -1.5px;
		background: linear-gradient(135deg, #fff 50%, rgba(99, 102, 241, 0.7));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.page-subtitle {
		margin-top: 0.8rem;
		font-size: 1rem;
		color: rgba(255, 255, 255, 0.4);
		font-weight: 400;
		letter-spacing: 0.5px;
		max-width: 500px;
	}

	.title-line {
		margin-top: 1.5rem;
		height: 2px;
		width: 80px;
		background: linear-gradient(90deg, #6366f1, #06b6d4);
		transform-origin: left;
		animation: expandLine 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s both;
	}

	/* --- CONTACT CARDS --- */
	.contact-grid {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.contact-card {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		text-decoration: none;
		color: inherit;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 16px;
		padding: 1.5rem 2rem;
		opacity: 0;
		animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) var(--delay) forwards;
		transition: border-color 0.4s ease, background 0.4s ease, transform 0.4s ease;
	}

	.contact-card:hover {
		background: rgba(255, 255, 255, 0.05);
		transform: translateX(6px);
	}

	.contact-card:hover .card-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	.contact-card:hover .card-icon {
		transform: scale(1.1);
	}

	/* Color accents per platform */
	.contact-card:hover:has(.linkedin) {
		border-color: rgba(10, 102, 194, 0.4);
	}
	.contact-card:hover:has(.github) {
		border-color: rgba(255, 255, 255, 0.2);
	}
	.contact-card:hover:has(.instagram) {
		border-color: rgba(225, 48, 108, 0.4);
	}
	.contact-card:hover:has(.x-twitter) {
		border-color: rgba(255, 255, 255, 0.2);
	}
	.contact-card:hover:has(.discord) {
		border-color: rgba(88, 101, 242, 0.4);
	}

	.card-icon {
		flex-shrink: 0;
		color: rgba(255, 255, 255, 0.5);
		transition: color 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.contact-card:hover .card-icon.linkedin { color: #0a66c2; }
	.contact-card:hover .card-icon.github { color: #fff; }
	.contact-card:hover .card-icon.instagram { color: #e1306c; }
	.contact-card:hover .card-icon.x-twitter { color: #fff; }
	.contact-card:hover .card-icon.discord { color: #5865f2; }

	.card-info {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.card-title {
		font-size: 1.05rem;
		font-weight: 600;
		letter-spacing: -0.3px;
	}

	.card-value {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.78rem;
		color: rgba(255, 255, 255, 0.3);
		letter-spacing: 0.5px;
	}

	.card-arrow {
		flex-shrink: 0;
		color: rgba(255, 255, 255, 0.15);
		opacity: 0;
		transform: translateX(-8px);
		transition: opacity 0.3s ease, transform 0.3s ease, color 0.3s ease;
	}

	.contact-card:hover .card-arrow {
		color: #6366f1;
	}

	/* --- FOOTER --- */
	.section-footer {
		margin-top: 3.5rem;
		opacity: 0;
		animation: fadeIn 0.6s ease-out 1.1s forwards;
	}

	/* --- RESPONSIVE --- */
	@media (max-width: 768px) {
		.top-nav {
			padding: 1.5rem;
			flex-direction: column;
			gap: 1rem;
			align-items: flex-start;
		}

		.nav-links {
			gap: 1.2rem;
		}

		.content-wrapper {
			padding: 1.5rem 1.5rem 3rem;
		}

		.contact-card {
			padding: 1.3rem 1.5rem;
			gap: 1.2rem;
		}

		.page-header {
			margin-bottom: 2.5rem;
		}
	}

	@media (max-width: 480px) {
		.top-nav {
			padding: 1rem;
		}

		.nav-links {
			gap: 1rem;
			font-size: 0.7rem;
		}

		.content-wrapper {
			padding: 1rem 1rem 2rem;
		}

		.contact-card {
			padding: 1.2rem;
			gap: 1rem;
		}

		.card-icon svg {
			width: 26px;
			height: 26px;
		}

		.card-title {
			font-size: 0.95rem;
		}

		.card-value {
			font-size: 0.7rem;
		}

		.card-arrow {
			display: none;
		}

		.bg-glow {
			width: 300px;
			height: 300px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		*, *::before, *::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
		}
	}
</style>
