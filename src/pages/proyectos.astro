		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.card-badge::before {
		content: '';
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #22c55e;
		animation: pulse 2s ease-in-out infinite;
	}

	.card-icon {
		color: #6366f1;
		margin-bottom: 1.5rem;
		opacity: 0.7;
		transition: opacity 0.3s ease;
	}

	.project-card:hover .card-icon {
		opacity: 1;
	}

	.card-title {
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 0.8rem;
		letter-spacing: -0.5px;
	}

	.card-description {
