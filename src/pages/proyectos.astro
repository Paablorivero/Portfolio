		border-radius: 6px;
		letter-spacing: 0.5px;
	}

	.card-link-hint {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1.5rem;
		font-size: 0.8rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.3);
		transition: color 0.3s ease, gap 0.3s ease;
	}

	.project-card:hover .card-link-hint {
		color: #6366f1;
		gap: 0.7rem;
	}

	/* --- GITHUB BANNER --- */
	.github-banner {
		display: block;
		text-decoration: none;
		color: inherit;
		opacity: 0;
		animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
	}

	.github-content {
