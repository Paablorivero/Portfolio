		}

		.page-header {
			margin-bottom: 2.5rem;
		}

		.github-content {
			padding: 1.5rem 2rem;
		}
	}

	@media (max-width: 480px) {
		.top-nav {
			padding: 1rem;
		}

		.nav-links {
			gap: 1rem;
			font-size: 0.7rem;
		}

		.content-wrapper {
			padding: 1rem 1rem 2rem;
		}

		.card-inner {
			padding: 1.5rem;
		}

		.card-title {
			font-size: 1.25rem;
		}

		.card-description {
			font-size: 0.85rem;
		}

		.github-content {
			padding: 1.2rem 1.5rem;
			gap: 1rem;
		}

		.github-title {
			font-size: 0.9rem;
		}

		.bg-glow {
			width: 300px;
			height: 300px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		*, *::before, *::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
		}
	}
</style>
