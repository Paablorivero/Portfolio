		opacity: 0;
		animation: slideInLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
	}

	.section-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.8rem;
		color: #6366f1;
		letter-spacing: 2px;
		display: block;
		margin-bottom: 1rem;
	}

	.page-title {
